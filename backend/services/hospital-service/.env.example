# Server Configuration
NODE_ENV=development
PORT=5003
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mediroutex_db
DB_USER=mediroutex
DB_PASSWORD=mediroutex_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Capacity Alerts
LOW_CAPACITY_THRESHOLD_PERCENT=20
CRITICAL_CAPACITY_THRESHOLD_PERCENT=10

# Service URLs
EMERGENCY_SERVICE_URL=http://localhost:5001
AMBULANCE_SERVICE_URL=http://localhost:5002
ROUTING_SERVICE_URL=http://localhost:5005

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
