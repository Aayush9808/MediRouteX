# Server Configuration
NODE_ENV=development
PORT=5005
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mediroutex_db
DB_USER=mediroutex
DB_PASSWORD=mediroutex_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Routing Configuration
DEFAULT_AMBULANCE_SPEED_KMH=50
EMERGENCY_SPEED_MULTIPLIER=1.2
TRAFFIC_UPDATE_INTERVAL_MINUTES=5
ROUTE_CACHE_TTL_SECONDS=300

# External APIs (Optional - for real map data)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Service URLs
EMERGENCY_SERVICE_URL=http://localhost:5001
AMBULANCE_SERVICE_URL=http://localhost:5002
HOSPITAL_SERVICE_URL=http://localhost:5003

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
