# Server Configuration
ENVIRONMENT=development
HOST=0.0.0.0
PORT=5006
API_VERSION=v1

# Database
DATABASE_URL=postgresql://mediroutex:mediroutex_password@localhost:5432/mediroutex_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256

# ML Model Configuration
MODEL_CACHE_DIR=./models
MODEL_UPDATE_INTERVAL_HOURS=24
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# Training Configuration
TRAINING_DAYS_HISTORY=90
MIN_TRAINING_SAMPLES=100
AUTO_RETRAIN_ENABLED=true
RETRAIN_INTERVAL_DAYS=7

# Prediction Settings
FORECAST_HORIZON_HOURS=24
DEMAND_GRID_SIZE_KM=5
HEATMAP_RESOLUTION=50

# External Services
EMERGENCY_SERVICE_URL=http://localhost:5001
AMBULANCE_SERVICE_URL=http://localhost:5002
HOSPITAL_SERVICE_URL=http://localhost:5003

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/ml-service.log

# CORS
CORS_ORIGINS=["http://localhost:3000"]
